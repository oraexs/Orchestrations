{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: codingAgent",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/agent/codingAgent.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "stopOnEntry": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}",
                "PYTHONUNBUFFERED": "1"
            },
            "cwd": "${workspaceFolder}"
        }
    ]
}